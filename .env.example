# --- Supabase (database of processed episodes) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# --- Groq (free Whisper STT + free LLM) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
GROQ_STT_MODEL=whisper-large-v3-turbo
# Qwen handles Chinese source transcripts (both podcast sources are Chinese)
# far more reliably than Llama, which frequently answered in Chinese instead
# of translating to Persian. See summarizer.py for why reasoning_effort matters.
GROQ_LLM_MODEL=qwen/qwen3.6-27b

# --- Telegram ---
# Create a bot with @BotFather, add it as admin to your channel
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHANNEL_ID=@your_channel_username_or_-100xxxxxxxxxx

# --- Sources ---
CROSSINGPODCAST_API=https://crossingpodcast.com/api/trpc/episodes.list
SV101_RSS_URL=https://feeds.fireside.fm/sv101/rss

# --- Behavior ---
# How many minutes between each check when running in --loop mode
CHECK_INTERVAL_MINUTES=60
# Max episodes to backfill/process per run (safety cap)
MAX_EPISODES_PER_RUN=3
# Minimum minutes between two phase-2 (backlog) episodes actually getting
# processed, regardless of how often main.py itself is invoked -- keeps
# Groq's daily token cap safe even if the GitHub Actions schedule (which
# fires 4x/hour as a safety net) ends up firing more than once per hour.
MIN_BACKLOG_INTERVAL_MINUTES=50
# Working directory for temporary audio downloads
TEMP_DIR=./tmp_audio
